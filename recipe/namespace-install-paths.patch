From: Oliver Lantwin <oliver@lantwin.de>
Subject: Namespace install destinations under cetmodules/

Upstream installs CMake helper modules to <prefix>/Modules/ and the
make_bash_completions helper to <prefix>/bin/. On a shared prefix (conda
env, /usr/local) these top-level destinations collide with files shipped
by other packages, since names like "Modules" and "make_bash_completions"
are not unique.

Relocate them under cetmodules-specific subdirectories:
  Modules/*.cmake          -> share/cetmodules/Modules/
  Modules/compat-aux/*     -> share/cetmodules/Modules/compat-aux/
  bin/make_bash_completions -> ${CMAKE_INSTALL_LIBEXECDIR} (libexec/cetmodules/)

The internal helpers (checkClassVersion, filter-program-options, ...) are
already installed under ${cetmodules_LIBEXEC_DIR}, which build.sh points at
libexec/cetmodules via -DCMAKE_INSTALL_LIBEXECDIR, so they need no change.

Downstream find_package(cetmodules) consumers are unaffected: the path
registered with cet_cmake_module_directories() is what cetmodulesConfig.cmake
bakes into CMAKE_MODULE_PATH.

In this release (3.24.01) make_bash_completions is bundled with the other
public scripts in a single cet_script() call, so it is split out into its
own cet_script() with an explicit libexec DESTINATION. We use
${CMAKE_INSTALL_LIBEXECDIR} rather than the project_variable
${cetmodules_LIBEXEC_DIR}: the latter is only defined once
libexec/CMakeLists.txt has been processed.

The make_bash_completions script previously located its companion
filter-program-options via "${BASH_SOURCE%/*}/../libexec". Once the script
itself lives in libexec/cetmodules/ alongside that companion, the relative
path is just the script's own directory.

diff --git a/CMakeLists.txt b/CMakeLists.txt
index 1c26e4a..33092b0 100644
--- a/CMakeLists.txt
+++ b/CMakeLists.txt
@@ -66,7 +66,7 @@ project_variable(MIN_CMAKE_VERSION TYPE STRING CONFIG
   DOCSTRING "Minimum version of CMake compatible with this version---${cetmodules_VERSION}---of cetmodules")
 
 # Make sure downstream packages can find our modules.
-cet_cmake_module_directories(NO_LOCAL Modules Modules/compat)
+cet_cmake_module_directories(NO_LOCAL share/cetmodules/Modules share/cetmodules/Modules/compat)
 
 ####################################
 # Build components.
diff --git a/Modules/CMakeLists.txt b/Modules/CMakeLists.txt
index 595a392..bd8863d 100644
--- a/Modules/CMakeLists.txt
+++ b/Modules/CMakeLists.txt
@@ -18,20 +18,20 @@ file(WRITE "${CMAKE_CURRENT_BINARY_DIR}/CetWritePackageVersionFile.cmake" "${con
 list(APPEND generated_modules
   "${CMAKE_CURRENT_BINARY_DIR}/CetWritePackageVersionFile.cmake")
 
-install(DIRECTORY ./ DESTINATION Modules
+install(DIRECTORY ./ DESTINATION share/cetmodules/Modules
   FILES_MATCHING PATTERN "*.cmake" PATTERN "[.#]*.cmake" EXCLUDE)
 
 file(COPY . DESTINATION .
   FILES_MATCHING PATTERN "*.cmake" PATTERN "[.#]*.cmake" EXCLUDE)
 
-install(FILES ${generated_modules} DESTINATION Modules)
+install(FILES ${generated_modules} DESTINATION share/cetmodules/Modules)
 
 file(MAKE_DIRECTORY ${CMAKE_CURRENT_BINARY_DIR}/compat-aux)
 file(COPY_FILE ${CMAKE_CURRENT_SOURCE_DIR}/compat/FindRange-v3.cmake
   ${CMAKE_CURRENT_BINARY_DIR}/compat-aux/Findrange-v3.cmake ONLY_IF_DIFFERENT)
 file(INSTALL ${CMAKE_CURRENT_BINARY_DIR}/compat-aux/Findrange-v3.cmake
-  DESTINATION Modules/compat-aux)
-cet_cmake_module_directories(NO_LOCAL Modules/compat-aux)
+  DESTINATION share/cetmodules/Modules/compat-aux)
+cet_cmake_module_directories(NO_LOCAL share/cetmodules/Modules/compat-aux)
 
 
 ########################################################################
diff --git a/bin/CMakeLists.txt b/bin/CMakeLists.txt
index f1a5fe6..967c91a 100644
--- a/bin/CMakeLists.txt
+++ b/bin/CMakeLists.txt
@@ -5,8 +5,7 @@
 set(public_programs
   filter-output
   format-code
-  intersphinx-refs
-  make_bash_completions)
+  intersphinx-refs)
 
 set(legacy_public_programs
   buildtool
@@ -25,5 +24,10 @@ set(public_files cet_test_functions.sh)
 
 cet_script(${public_programs} ${legacy_public_programs})
 
+# make_bash_completions is an internal helper that locates its companion
+# filter-program-options alongside itself; install it under libexec/cetmodules/
+# rather than bin/ so a shared prefix isn't polluted with a generic name.
+cet_script(make_bash_completions DESTINATION ${CMAKE_INSTALL_LIBEXECDIR})
+
 install(FILES ${public_files} DESTINATION ${cetmodules_BIN_DIR})
 install(PROGRAMS ${legacy_compat} DESTINATION ${cetmodules_BIN_DIR})
diff --git a/bin/make_bash_completions b/bin/make_bash_completions
index 32713a3..b4c4e88 100755
--- a/bin/make_bash_completions
+++ b/bin/make_bash_completions
@@ -11,7 +11,7 @@
 # =========================================================================
 
 # Private utilities.
-libexec=$(cd "${BASH_SOURCE%/*}/../libexec" && pwd -P)
+libexec=$(cd "${BASH_SOURCE%/*}" && pwd -P)
 
 # Arguments.
 output="$1"; shift
