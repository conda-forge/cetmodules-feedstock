-  DESTINATION Modules/compat-aux)
-cet_cmake_module_directories(NO_LOCAL Modules/compat-aux)
+  DESTINATION share/cetmodules/Modules/compat-aux)
+cet_cmake_module_directories(NO_LOCAL share/cetmodules/Modules/compat-aux)
 
 
 ########################################################################
 # Generate plugin builds for compatibility.
-set(dest_subdir Modules/compat/art)
+set(dest_subdir share/cetmodules/Modules/compat/art)
 
 # Function to reduce duplication when generating the art suite plugin
 # builders for compatibility,
diff --git a/Modules/CetMakeCompletions.cmake b/Modules/CetMakeCompletions.cmake
index bf9d4ec..dc8df33 100644
--- a/Modules/CetMakeCompletions.cmake
+++ b/Modules/CetMakeCompletions.cmake
@@ -68,7 +68,7 @@ cmake_minimum_required(VERSION 3.18.2...3.27 FATAL_ERROR)
 #]================================================================]
 
 function(cet_make_completions exec)
-  cet_localize_pv(cetmodules BIN_DIR)
+  cet_localize_pv(cetmodules BIN_DIR LIBEXEC_DIR)
   if (NOT TARGET "${exec}")
     message(ERROR "cet_make_completions(): \"${exec}\" is not a target")
   endif()
@@ -81,12 +81,12 @@ function(cet_make_completions exec)
   endif()
   add_custom_command(
     OUTPUT "${output_file}"
-    COMMAND "${cetmodules_BIN_DIR}/make_bash_completions"
+    COMMAND "${cetmodules_LIBEXEC_DIR}/make_bash_completions"
     "${output_file}" "${exec}" ${user_provided_completions}
     VERBATIM
     COMMAND_EXPAND_LISTS
     COMMENT "${completion_comment}"
-    DEPENDS "${cetmodules_BIN_DIR}/make_bash_completions"
+    DEPENDS "${cetmodules_LIBEXEC_DIR}/make_bash_completions"
   )
   add_custom_target(MakeCompletions_${exec} ALL
     DEPENDS ${CMAKE_CURRENT_BINARY_DIR}/${exec}_completions)
diff --git a/bin/CMakeLists.txt b/bin/CMakeLists.txt
index f1a5fe6..967c91a 100644
--- a/bin/CMakeLists.txt
+++ b/bin/CMakeLists.txt
@@ -5,8 +5,7 @@
 set(public_programs
   filter-output
   format-code
-  intersphinx-refs
-  make_bash_completions)
+  intersphinx-refs)
 
 set(legacy_public_programs
   buildtool
@@ -25,5 +24,10 @@ set(public_files cet_test_functions.sh)
 
 cet_script(${public_programs} ${legacy_public_programs})
 
+# make_bash_completions is an internal helper that locates its companion
+# filter-program-options alongside itself; install it under libexec/cetmodules/
+# rather than bin/ so a shared prefix isn't polluted with a generic name.
+cet_script(make_bash_completions DESTINATION ${CMAKE_INSTALL_LIBEXECDIR})
+
 install(FILES ${public_files} DESTINATION ${cetmodules_BIN_DIR})
 install(PROGRAMS ${legacy_compat} DESTINATION ${cetmodules_BIN_DIR})
